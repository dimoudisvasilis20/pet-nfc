PORT=3000

SESSION_SECRET=change-me-to-a-long-random-string

# Either set DATABASE_URL (preferred on most hosts, e.g. Render/Railway/Neon)...
DATABASE_URL=

# ...or set these individually (used for local development):
DB_HOST=localhost
DB_PORT=5432
DB_NAME=pet_nfc
DB_USER=postgres
DB_PASSWORD=

# Public base URL of this site — used to build links in emails (e.g. the
# email verification link). No trailing slash.
APP_BASE_URL=http://localhost:3000

# Resend (resend.com) — used to send the welcome/verification email.
RESEND_API_KEY=
EMAIL_FROM=PawTrace <onboarding@resend.dev>

# Google OAuth — from a Web application OAuth 2.0 Client ID in Google Cloud
# Console. GOOGLE_REDIRECT_URI must exactly match an Authorized redirect URI
# configured there (this app's callback route is /auth/google/callback).
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/auth/google/callback
